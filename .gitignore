# ───────────────────────────── Unity ─────────────────────────────
# Generated / cache folders — never commit these.
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
.[Cc]onsulo/

# Asset meta data should only be ignored when the asset itself is ignored.
!/[Aa]ssets/**/*.meta

# Unity-generated crash/burst/backup artifacts (Unity tells you not to ship these).
*_BurstDebugInformation_DoNotShip/
*_BackUpThisFolder_ButDontShipItWithYourGame/
sysinfo.txt
crashlytics-build.properties

# Recovered scene backups (local-only).
/[Aa]ssets/_Recovery/

# ───────────────────────── Build outputs ─────────────────────────
*.apk
*.aab
*.unitypackage
*.app
ExportedObj/
.consulo/

# ──────────────────── IDE / project generated ────────────────────
ExportedObj/
.vs/
.vscode/
.idea/
.gradle/
.utmp/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# OS files
.DS_Store
Thumbs.db

# ───────────────────────── AI / assistant ────────────────────────
# Do not commit any assistant-generated bookkeeping files.
CLAUDE.md
**/CLAUDE.md
.claude/
**/.claude/
*.claude
.cursor/
.aider*
